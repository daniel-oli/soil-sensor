#include <WiFiEsp.h>
#include <ArduinoJson.h>
#include <ModbusMaster.h>

// ==========================================
// CONFIGURAÇÕES DA REDE E SERVIDOR
// ==========================================
char ssid[] = "Sinildo";
char pass[] = "junior123";
char servidor[] = "10.118.141.96";   // IP do PC com Node.js
int portaServidor = 3000;            // Mesma porta do server.js

WiFiEspClient clienteHttp;

// ==========================================
// PINAGEM E HARDWARE
// ==========================================
#define PINO_CONTROLE_RS485 4

ModbusMaster sensorSolo;

// ==========================================
// CONTROLE RS485
// ==========================================
void iniciarTransmissao() {
  digitalWrite(PINO_CONTROLE_RS485, HIGH);
}

void finalizarTransmissao() {
  digitalWrite(PINO_CONTROLE_RS485, LOW);
}

// ==========================================
// SETUP
// ==========================================
void setup() {
  Serial.begin(4800);

  pinMode(PINO_CONTROLE_RS485, OUTPUT);
  finalizarTransmissao();
  Serial1.begin(4800);

  sensorSolo.begin(1, Serial1);
  sensorSolo.preTransmission(iniciarTransmissao);
  sensorSolo.postTransmission(finalizarTransmissao);

  Serial3.begin(115200);
  WiFi.init(&Serial3);

  if (WiFi.status() == WL_NO_SHIELD) {
    Serial.println("[ERRO] ESP-01 não detectado.");
    while (true);
  }

  conectarWiFi();
}

// ==========================================
// LOOP
// ==========================================
void loop() {
  if (WiFi.status() != WL_CONNECTED) {
    conectarWiFi();
  }

  float umidade, temperatura, ec, ph, n, p, k;

  if (lerSensorModbus(&umidade, &temperatura, &ec, &ph, &n, &p, &k)) {
    String json = montarJson(umidade, temperatura, ph, ec, n, p, k);
    enviarDadosParaServidor(json);
  } else {
    Serial.println("[AVISO] Falha na leitura Modbus.");
  }

  delay(10000); // 10 segundos
}

// ==========================================
// FUNÇÕES
// ==========================================
void conectarWiFi() {
  Serial.print("[WIFI] Conectando em ");
  Serial.println(ssid);

  if (WiFi.begin(ssid, pass) == WL_CONNECTED) {
    Serial.println("[WIFI] Conectado!");
    Serial.print("[WIFI] IP da placa: ");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println("[WIFI] Falha ao conectar.");
  }
}

bool lerSensorModbus(float* umidade, float* temp, float* ec, float* ph, float* n, float* p, float* k) {
  uint8_t status = sensorSolo.readHoldingRegisters(0x0000, 7);

  if (status == sensorSolo.ku8MBSuccess) {
    *umidade = sensorSolo.getResponseBuffer(0) / 10.0;
    *temp    = sensorSolo.getResponseBuffer(1) / 10.0;
    *ec      = sensorSolo.getResponseBuffer(2);       // µS/cm
    *ph      = sensorSolo.getResponseBuffer(3) / 10.0;
    *n       = sensorSolo.getResponseBuffer(4);
    *p       = sensorSolo.getResponseBuffer(5);
    *k       = sensorSolo.getResponseBuffer(6);
    return true;
  }

  return false;
}

String montarJson(float umidade, float temp, float ph, float ec, float n, float p, float k) {
  StaticJsonDocument<256> doc;

  // Campos EXATOS esperados pelo backend
  doc["temperatura"] = temp;
  doc["umidade"] = umidade;
  doc["ph"] = ph;
  doc["condutividade"] = ec;
  doc["nitrogenio"] = n;
  doc["fosforo"] = p;
  doc["potassio"] = k;

  String saida;
  serializeJson(doc, saida);
  return saida;
}

void enviarDadosParaServidor(String json) {
  if (clienteHttp.connect(servidor, portaServidor)) {
    Serial.println("[HTTP] Enviando...");

    clienteHttp.println("POST /sensor HTTP/1.1");   // endpoint correto
    clienteHttp.print("Host: ");
    clienteHttp.println(servidor);
    clienteHttp.println("Content-Type: application/json");
    clienteHttp.println("Connection: close");
    clienteHttp.print("Content-Length: ");
    clienteHttp.println(json.length());
    clienteHttp.println();
    clienteHttp.println(json);

    Serial.println("[HTTP] Resposta:");
    unsigned long timeout = millis();
    while (clienteHttp.connected() && millis() - timeout < 5000) {
      while (clienteHttp.available()) {
        Serial.write(clienteHttp.read());
        timeout = millis();
      }
    }

    clienteHttp.stop();
    Serial.println("\n[HTTP] Fim.");
  } else {
    Serial.println("[HTTP] Erro ao conectar no servidor.");
  }
}
